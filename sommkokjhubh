<!-- ═══════════════════════════════════════════════════════════════
     STASIS PRO — APPLICATION LOGIC
     ─────────────────────────────────────────────────────────────
     Module architecture:
       App.Console — timestamped log renderer + export
       App.Storage — localStorage persistence (namespaced)
       App.Audio   — Web Audio API synthesis engine
       App.Timer   — countdown engine + SVG ring + state
       App.Missions— mission CRUD + localStorage sync
       App.UI      — DOM bindings, render helpers
       App.init()  — boot sequence
═══════════════════════════════════════════════════════════════ -->
<script>
'use strict';

/* ══════════════════════════════════════════════════════════════
   APP NAMESPACE — all modules live here, zero global leakage
══════════════════════════════════════════════════════════════ */
const App = {};

/* ──────────────────────────────────────────────────────────────
   SHARED STATE — single source of truth, mutated only by modules
────────────────────────────────────────────────────────────── */
App.State = {
  /* Timer */
  running:          false,
  paused:           false,
  totalSecs:        25 * 60,
  remainingSecs:    25 * 60,
  elapsedSecs:      0,
  durationMins:     25,
  mode:             'focus',
  intervalId:       null,

  /* Persisted stats */
  sessions:         0,
  focusMins:        0,
  streak:           0,
  lastDate:         null,

  /* Flags */
  audioReady:       false,
};

/* Session mode presets */
App.MODES = {
  focus: { label:'DEEP FOCUS',  tag:'FOCUS',   mins:25 },
  flow:  { label:'FLOW STATE',  tag:'FLOW',    mins:52 },
  break: { label:'SHORT BREAK', tag:'BREAK',   mins:5  },
  long:  { label:'LONG BREAK',  tag:'LONG BRK',mins:15 },
};


/* ══════════════════════════════════════════════════════════════
   App.Console — SYSTEM LOG MODULE
   ──────────────────────────────────────────────────────────────
   Renders timestamped, level-tagged entries into the terminal
   dock. Maintains an internal buffer for export. Auto-prunes
   DOM entries beyond MAX_LINES to prevent memory pressure.
══════════════════════════════════════════════════════════════ */
App.Console = (function () {
  const MAX_LINES = 180;
  let domCount = 0;
  const buffer = [];  /* [{ts, level, msg}] for export */

  /**
   * ts — returns HH:MM:SS timestamp string
   * @returns {string}
   */
  function ts() {
    const n = new Date(), p = n => String(n).padStart(2,'0');
    return `${p(n.getHours())}:${p(n.getMinutes())}:${p(n.getSeconds())}`;
  }

  /**
   * esc — minimal HTML escape to prevent XSS in user-supplied text
   * @param {string} s
   * @returns {string}
   */
  function esc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  /**
   * log — append a styled entry to the console output pane.
   * @param {string} msg
   * @param {'system'|'info'|'success'|'warn'|'error'} lvl
   */
  function log(msg, lvl = 'info') {
    const out = document.getElementById('con-out');
    if (!out) return;

    const stamp = ts();
    buffer.push({ stamp, lvl, msg });

    /* Prune DOM if over limit */
    while (domCount >= MAX_LINES) {
      const first = out.querySelector('.log-line');
      if (first) { out.removeChild(first); domCount--; } else break;
    }

    const line = document.createElement('div');
    line.className = 'log-line';
    line.innerHTML =
      `<span class="l-ts">[${stamp}]</span>` +
      `<span class="l-lvl ${lvl}">${lvl.toUpperCase().padEnd(7)}</span>` +
      `<span class="l-msg">${esc(msg)}</span>`;

    out.appendChild(line);
    domCount++;

    /* Scroll to latest */
    requestAnimationFrame(() => { out.scrollTop = out.scrollHeight; });
  }

  /**
   * clear — wipe all log entries from DOM + reset buffer
   */
  function clear() {
    const out = document.getElementById('con-out');
    if (out) out.innerHTML = '';
    domCount = 0;
    buffer.length = 0;
    log('Console cleared.', 'system');
  }

  /**
   * exportLog — download buffer as plain-text .txt file
   */
  function exportLog() {
    const text = buffer.map(e => `[${e.stamp}] [${e.lvl.toUpperCase()}] ${e.msg}`).join('\n');
    const blob = new Blob([text], { type:'text/plain' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href = url; a.download = `stasis-log-${Date.now()}.txt`; a.click();
    URL.revokeObjectURL(url);
    log('Log exported to disk.', 'success');
  }

  return { log, clear, exportLog };
}());


/* ══════════════════════════════════════════════════════════════
   App.Storage — LOCALSTORAGE PERSISTENCE MODULE
   ──────────────────────────────────────────────────────────────
   All keys are prefixed 'sp:' (stasis-pro) to prevent collisions.
   All operations are wrapped in try/catch — storage may be
   blocked in private browsing / certain iframe contexts.
══════════════════════════════════════════════════════════════ */
App.Storage = (function () {
  const PFX = 'sp:';

  function ok() {
    try { localStorage.setItem('__t__','1'); localStorage.removeItem('__t__'); return true; }
    catch { return false; }
  }

  /**
   * set — JSON-serialize and write to localStorage
   * @param {string} key
   * @param {*} val
   */
  function set(key, val) {
    if (!ok()) return;
    try { localStorage.setItem(PFX + key, JSON.stringify(val)); }
    catch(e) { App.Console.log(`Storage.set error [${key}]: ${e.message}`, 'error'); }
  }

  /**
   * get — read and JSON-parse from localStorage, with fallback
   * @param {string} key
   * @param {*} fallback
   * @returns {*}
   */
  function get(key, fallback = null) {
    if (!ok()) return fallback;
    try {
      const r = localStorage.getItem(PFX + key);
      return r !== null ? JSON.parse(r) : fallback;
    } catch(e) {
      App.Console.log(`Storage.get error [${key}]: ${e.message}`, 'error');
      return fallback;
    }
  }

  /* ── Stats helpers ── */

  /** loadStats — restore persisted counters into App.State */
  function loadStats() {
    App.State.sessions  = get('sessions', 0);
    App.State.focusMins = get('focus_mins', 0);
    App.State.streak    = get('streak', 0);
    App.State.lastDate  = get('last_date', null);
    App.Console.log(
      `Stats loaded — sessions:${App.State.sessions}  focus:${App.State.focusMins}m  streak:${App.State.streak}`,
      'system'
    );
  }

  /** saveStats — flush current App.State counters to localStorage */
  function saveStats() {
    set('sessions',   App.State.sessions);
    set('focus_mins', App.State.focusMins);
    set('streak',     App.State.streak);
    set('last_date',  App.State.lastDate);
  }

  /* ── Mission helpers ── */

  /** @returns {Array<{id,text,done,at}>} */
  function loadMissions()       { return get('missions', []); }

  /** @param {Array} ms */
  function saveMissions(ms)     { set('missions', ms); }

  return { set, get, loadStats, saveStats, loadMissions, saveMissions };
}());


/* ══════════════════════════════════════════════════════════════
   App.Audio — WEB AUDIO API SYNTHESIS ENGINE
   ──────────────────────────────────────────────────────────────
   Generates ALL sounds procedurally. No external audio files.

   RAIN  : White noise → Bandpass filter → High-shelf → Gain
   FOREST: Pink noise  → Lowpass filter  → Convolver (reverb) → Gain
           + Sparse bird-chirp oscillator events via setTimeout

   Volume changes use exponentialRampToValueAtTime to eliminate
   audible clicks/pops at gain transitions.
══════════════════════════════════════════════════════════════ */
App.Audio = (function () {

  /** @type {AudioContext|null} */
  let ctx = null;

  /* Per-track state objects */
  const T = {
    rain:   { src: null, gain: null, vol: 0, started: false },
    forest: { src: null, gain: null, vol: 0, started: false },
  };

  /* Cached reverb impulse response buffer */
  let irBuf = null;

  /* Bird scheduler timer handle */
  let birdTimer = null;

  /* ──────────────────────────────────────────────────────────
     BUFFER GENERATORS
  ────────────────────────────────────────────────────────── */

  /**
   * makeWhiteNoise — fills an AudioBuffer with uniform random samples.
   * White noise has equal energy at all frequencies.
   * Used as raw material for the rain synthesis.
   * @param {number} secs
   * @returns {AudioBuffer}
   */
  function makeWhiteNoise(secs) {
    const sr    = ctx.sampleRate;
    const buf   = ctx.createBuffer(1, sr * secs, sr);
    const data  = buf.getChannelData(0);
    for (let i = 0; i < data.length; i++) data[i] = Math.random() * 2 - 1;
    return buf;
  }

  /**
   * makePinkNoise — Paul Kellett's 7-coefficient pink noise approximation.
   * Pink noise rolls off at ~-3 dB/octave, resembling natural ambiences
   * (wind, forest, distant traffic). Used as forest base.
   * @param {number} secs
   * @returns {AudioBuffer}
   */
  function makePinkNoise(secs) {
    const sr   = ctx.sampleRate;
    const buf  = ctx.createBuffer(1, sr * secs, sr);
    const data = buf.getChannelData(0);
    let b0=0, b1=0, b2=0, b3=0, b4=0, b5=0, b6=0;
    for (let i = 0; i < data.length; i++) {
      const w = Math.random() * 2 - 1;
      b0 = 0.99886*b0 + w*0.0555179;
      b1 = 0.99332*b1 + w*0.0750759;
      b2 = 0.96900*b2 + w*0.1538520;
      b3 = 0.86650*b3 + w*0.3104856;
      b4 = 0.55000*b4 + w*0.5329522;
      b5 = -0.7616*b5 - w*0.0168980;
      const pink = (b0+b1+b2+b3+b4+b5+b6 + w*0.5362) * 0.11;
      b6 = w * 0.115926;
      data[i] = pink;
    }
    return buf;
  }

  /**
   * makeIR — generates a synthetic reverb Impulse Response.
   * Stereo exponentially-decaying white noise simulates room acoustics.
   * Gives the forest ambience a spatial, immersive quality.
   * @param {number} secs   - reverb tail length in seconds
   * @param {number} decay  - decay exponent (higher = shorter tail)
   * @returns {AudioBuffer}
   */
  function makeIR(secs = 3.2, decay = 2.4) {
    const sr  = ctx.sampleRate;
    const len = sr * secs;
    const buf = ctx.createBuffer(2, len, sr);
    for (let ch = 0; ch < 2; ch++) {
      const d = buf.getChannelData(ch);
      for (let i = 0; i < len; i++) {
        d[i] = (Math.random()*2-1) * Math.pow(1 - i/len, decay);
      }
    }
    return buf;
  }

  /* ──────────────────────────────────────────────────────────
     RAIN CHAIN
     WhiteNoise → BandpassFilter(600Hz) → HighShelf(+5dB@3kHz) → Gain
  ────────────────────────────────────────────────────────── */

  /**
   * startRain — creates and connects the rain synthesis subgraph.
   * The bandpass filter sculpts white noise into a rain-texture;
   * the high-shelf boosts the characteristic high-frequency hiss.
   */
  function startRain() {
    if (T.rain.started) return;

    const buf = makeWhiteNoise(10);           /* 10s looping buffer  */
    const src = ctx.createBufferSource();
    src.buffer = buf; src.loop = true;

    /* Bandpass: rain energy centers around 400–800 Hz */
    const bp = ctx.createBiquadFilter();
    bp.type = 'bandpass'; bp.frequency.value = 580; bp.Q.value = 0.7;

    /* High shelf: +5 dB above 3 kHz for rain hiss */
    const hs = ctx.createBiquadFilter();
    hs.type = 'highshelf'; hs.frequency.value = 3000; hs.gain.value = 5;

    /* Master gain — silent at init */
    const gain = ctx.createGain();
    gain.gain.value = 0;

    src.connect(bp); bp.connect(hs); hs.connect(gain); gain.connect(ctx.destination);
    src.start(0);

    T.rain.src = src; T.rain.gain = gain; T.rain.started = true;
    App.Console.log('Audio.Rain  | chain: WhiteNoise → BPF(580Hz,Q0.7) → HiShelf(+5dB@3k) → Gain', 'system');
  }

  /* ──────────────────────────────────────────────────────────
     FOREST CHAIN
     PinkNoise → LowpassFilter(1.1kHz) → Convolver(IR) → Gain
     + Bird oscillator events via scheduleBirds()
  ────────────────────────────────────────────────────────── */

  /**
   * startForest — creates the forest synthesis subgraph.
   * Pink noise provides wind/leaf texture; convolver adds depth.
   */
  function startForest() {
    if (T.forest.started) return;

    const buf = makePinkNoise(12);
    const src = ctx.createBufferSource();
    src.buffer = buf; src.loop = true;

    /* Low-pass: cut >1.1 kHz, keeping forest's low-mid character */
    const lp = ctx.createBiquadFilter();
    lp.type = 'lowpass'; lp.frequency.value = 1100; lp.Q.value = 0.65;

    /* Build reverb convolver with cached IR */
    if (!irBuf) irBuf = makeIR(3.2, 2.4);
    const conv = ctx.createConvolver();
    conv.buffer = irBuf;

    /* Wet/dry blender */
    const dry = ctx.createGain(); dry.gain.value = 0.62;
    const wet = ctx.createGain(); wet.gain.value = 0.38;

    const gain = ctx.createGain(); gain.gain.value = 0;

    /* Wire: src → lp → [dry → gain] and [conv → wet → gain] */
    src.connect(lp);
    lp.connect(dry); dry.connect(gain);
    lp.connect(conv); conv.connect(wet); wet.connect(gain);
    gain.connect(ctx.destination);
    src.start(0);

    T.forest.src = src; T.forest.gain = gain; T.forest.started = true;

    scheduleBirds(); /* start sparse bird-call events */
    App.Console.log('Audio.Forest| chain: PinkNoise → LP(1.1kHz) → Convolver(IR 3.2s) → Gain + Birds', 'system');
  }

  /* ──────────────────────────────────────────────────────────
     BIRD CALL SYNTHESIZER
     Creates short frequency-modulated oscillator bursts at
     randomized intervals to simulate ambient birdsong.
  ────────────────────────────────────────────────────────── */

  /**
   * scheduleBirds — recursively schedules the next bird chirp.
   * Interval is randomized (4–14 s) so it doesn't sound mechanical.
   */
  function scheduleBirds() {
    const delay = 4000 + Math.random() * 10000;
    birdTimer = setTimeout(() => {
      if (T.forest.started && T.forest.vol > 0.04 && ctx) chirp();
      if (T.forest.started) scheduleBirds();
    }, delay);
  }

  /**
   * chirp — emits a single synthetic bird call.
   * Two frequency-modulated sine oscillators + amplitude envelope.
   * Pitch and timing are randomized for organic variation.
   */
  function chirp() {
    if (!ctx || !T.forest.gain) return;
    const now   = ctx.currentTime;
    const freq  = 2200 + Math.random() * 3800;     /* 2.2–6 kHz range  */
    const dur   = 0.07 + Math.random() * 0.18;     /* 70–250 ms        */
    const amp   = T.forest.vol * 0.28 * (0.45 + Math.random() * 0.55);
    const n     = Math.random() > 0.6 ? 2 : 1;     /* 1 or 2 syllables */

    for (let i = 0; i < n; i++) {
      const o  = ctx.createOscillator();
      const o2 = ctx.createOscillator();
      const g  = ctx.createGain();

      o.type  = 'sine'; o.frequency.value  = freq * (1 + i * 0.08);
      o2.type = 'sine'; o2.frequency.value = freq * 1.5 * (1 + i * 0.04);

      const start = now + i * (dur + 0.04);
      g.gain.setValueAtTime(0, start);
      g.gain.linearRampToValueAtTime(amp, start + 0.012);
      g.gain.exponentialRampToValueAtTime(0.0001, start + dur);

      o.connect(g); o2.connect(g); g.connect(T.forest.gain);
      o.start(start);  o.stop(start + dur + 0.015);
      o2.start(start); o2.stop(start + dur + 0.015);
    }
  }

  /* ──────────────────────────────────────────────────────────
     PUBLIC API
  ────────────────────────────────────────────────────────── */

  /**
   * init — creates AudioContext and boots all synthesis chains.
   * MUST be called from inside a user gesture (button click)
   * to satisfy browser autoplay policy.
   */
  function init() {
    if (ctx) return;
    try {
      ctx = new (window.AudioContext || window.webkitAudioContext)();
      App.Console.log(`Audio.ctx   | created — sampleRate:${ctx.sampleRate}Hz state:"${ctx.state}"`, 'system');
      startRain();
      startForest();

      /* Update mixer badge in sidebar */
      const badge = document.getElementById('mixer-badge');
      if (badge) { badge.textContent = 'ONLINE'; badge.style.color = 'var(--accent)'; }

      App.State.audioReady = true;
      App.Console.log('Audio.Engine| all synthesis chains ready. Adjust sliders to activate.', 'success');
    } catch (e) {
      App.Console.log(`Audio.init  | FAILED: ${e.message}`, 'error');
    }
  }

  /**
   * resume — re-activates a browser-suspended AudioContext.
   * Browsers suspend contexts on tab blur; call this on any interaction.
   */
  function resume() {
    if (ctx && ctx.state === 'suspended') {
      ctx.resume().then(() => App.Console.log('Audio.ctx   | resumed from suspended.', 'system'));
    }
  }

  /**
   * setVolume — ramps a track gain using an exponential curve
   * to eliminate audible clicks at transitions.
   * @param {'rain'|'forest'} name
   * @param {number} v — 0.0 to 1.0 linear
   * @param {number} ramp — seconds for ramp (default 60ms)
   */
  function setVolume(name, v, ramp = 0.06) {
    const t = T[name];
    if (!t || !t.gain || !ctx) return;
    t.vol = v;
    const now    = ctx.currentTime;
    const target = Math.max(0.0001, Math.min(1, v));
    t.gain.gain.cancelScheduledValues(now);
    t.gain.gain.setValueAtTime(t.gain.gain.value, now);
    if (v < 0.0001) t.gain.gain.exponentialRampToValueAtTime(0.0001, now + ramp);
    else            t.gain.gain.exponentialRampToValueAtTime(target, now + ramp);
  }

  return { init, resume, setVolume };
}());


/* ══════════════════════════════════════════════════════════════
   App.Timer — COUNTDOWN ENGINE + SVG RING
   ──────────────────────────────────────────────────────────────
   Drives the 1-second setInterval countdown, formats display
   strings, animates the SVG progress ring, handles completion.
   Uses font-variant-numeric:tabular-nums (set in CSS) to prevent
   layout jitter from variable-width digits.
══════════════════════════════════════════════════════════════ */
App.Timer = (function () {

  /* SVG ring geometry */
  const R    = 210;
  const CIRC = 2 * Math.PI * R;   /* ≈ 1319.47 px */

  /**
   * fmt — format raw seconds as MM:SS (always 5 chars, e.g. "09:07")
   * @param {number} s
   * @returns {string}
   */
  function fmt(s) {
    s = Math.max(0, Math.floor(s));
    return `${String(Math.floor(s/60)).padStart(2,'0')}:${String(s%60).padStart(2,'0')}`;
  }

  /**
   * fmtDur — human-readable elapsed string for log messages
   * @param {number} s seconds
   * @returns {string}
   */
  function fmtDur(s) {
    if (s < 60) return `${s}s`;
    const m = Math.floor(s/60); const r = s%60;
    return r ? `${m}m ${r}s` : `${m}m`;
  }

  /**
   * updateRing — sets the SVG dashoffset so the ring arc reflects
   * how much of the session remains.
   * dashoffset 0     = full circle (session not started)
   * dashoffset CIRC  = empty circle (session complete)
   * @param {number} rem - remaining seconds
   * @param {number} tot - total session seconds
   */
  function updateRing(rem, tot) {
    const el = document.getElementById('ring-fill');
    if (!el) return;
    const fraction = tot > 0 ? rem / tot : 1;
    const offset   = CIRC * (1 - fraction);
    if (!el.style.strokeDasharray) el.style.strokeDasharray = String(CIRC);
    el.style.strokeDashoffset = String(offset);
  }

  /**
   * render — pushes all timer-related values into DOM.
   * Called every tick and on any state transition.
   */
  function render() {
    const { remainingSecs, totalSecs, elapsedSecs, mode } = App.State;
    const m = App.MODES[mode];

    /* Clock face */
    const el = document.getElementById('timer');
    if (el) {
      el.textContent = fmt(remainingSecs);
      const pct = totalSecs > 0 ? remainingSecs / totalSecs : 1;
      el.classList.toggle('warn', pct <= 0.33 && pct > 0.10 && App.State.running);
      el.classList.toggle('crit', pct <= 0.10 && App.State.running);
    }

    /* Sub-labels */
    const modeEl = document.getElementById('t-mode');
    if (modeEl) modeEl.textContent = m.label;

    const elEl = document.getElementById('t-elapsed');
    if (elEl) elEl.textContent = `ELAPSED ${fmt(elapsedSecs)}`;

    /* Stats bar mode pill */
    const pill = document.getElementById('mode-pill');
    if (pill) pill.textContent = `${m.tag} · ${fmt(remainingSecs)}`;

    /* Ring */
    updateRing(remainingSecs, totalSecs);
  }

  /**
   * onComplete — fires when countdown reaches 0.
   * Updates + persists stats, resets state, notifies user.
   */
  function onComplete() {
    App.Console.log(`✓ Session complete — ${App.MODES[App.State.mode].label} ${fmtDur(App.State.totalSecs)}`, 'success');

    /* Increment stats for focus/flow sessions */
    if (App.State.mode === 'focus' || App.State.mode === 'flow') {
      App.State.sessions++;
      App.State.focusMins += App.State.durationMins;
      App.State.streak++;
      App.State.lastDate = new Date().toISOString();
      App.Console.log(
        `Stats — sessions:${App.State.sessions}  focus:${App.State.focusMins}m  streak:${App.State.streak}`,
        'info'
      );
    }

    App.Storage.saveStats();
    App.UI.renderStats();

    /* Reset engine state */
    clearInterval(App.State.intervalId);
    App.State.intervalId = null;
    App.State.running    = false;
    App.State.paused     = false;
    App.State.elapsedSecs = 0;
    App.State.remainingSecs = 0;

    document.getElementById('stage')?.classList.remove('running');

    const stxt = document.getElementById('status-txt');
    if (stxt) stxt.textContent = 'COMPLETE';

    const sbtn = document.getElementById('btn-start');
    if (sbtn) sbtn.textContent = '▶\u00A0\u00A0Start Session';

    render();

    /* Desktop notification (if permission granted) */
    if ('Notification' in window && Notification.permission === 'granted') {
      new Notification('STASIS PRO', {
        body: `${App.MODES[App.State.mode].label} session complete!`,
        silent: true,
      });
    }
  }

  /**
   * tick — core interval callback, fires every 1000ms.
   */
  function tick() {
    if (!App.State.running) return;
    App.State.remainingSecs = Math.max(0, App.State.remainingSecs - 1);
    App.State.elapsedSecs++;
    render();
    if (App.State.remainingSecs <= 0) onComplete();
  }

  /* ── Public controls ── */

  /** start — begin or resume countdown */
  function start() {
    if (App.State.running) return;

    if (!App.State.paused) {
      /* Fresh start — initialize from current duration */
      App.State.remainingSecs = App.State.durationMins * 60;
      App.State.totalSecs     = App.State.remainingSecs;
      App.State.elapsedSecs   = 0;
    }

    App.State.running = true;
    App.State.paused  = false;

    clearInterval(App.State.intervalId);
    App.State.intervalId = setInterval(tick, 1000);

    document.getElementById('stage')?.classList.add('running');

    const stxt = document.getElementById('status-txt');
    if (stxt) stxt.textContent = 'ACTIVE';

    const sbtn = document.getElementById('btn-start');
    if (sbtn) sbtn.textContent = '⏸\u00A0\u00A0Pause';

    App.Audio.resume();

    App.Console.log(
      `Timer started — ${App.MODES[App.State.mode].label} ${App.State.durationMins}m (${App.State.totalSecs}s)`,
      'info'
    );

    render();
  }

  /** pause — pause countdown, preserving remaining time */
  function pause() {
    if (!App.State.running) return;
    clearInterval(App.State.intervalId);
    App.State.intervalId = null;
    App.State.running    = false;
    App.State.paused     = true;

    document.getElementById('stage')?.classList.remove('running');

    const stxt = document.getElementById('status-txt');
    if (stxt) stxt.textContent = 'PAUSED';

    const sbtn = document.getElementById('btn-start');
    if (sbtn) sbtn.textContent = '▶\u00A0\u00A0Resume';

    App.Console.log(
      `Timer paused at ${fmt(App.State.remainingSecs)} (elapsed ${fmtDur(App.State.elapsedSecs)})`,
      'warn'
    );
  }

  /** toggle — primary button action: start ↔ pause */
  function toggle() {
    if (App.State.running) pause(); else start();
  }

  /** reset — stop and return to current duration */
  function reset() {
    clearInterval(App.State.intervalId);
    App.State.intervalId   = null;
    App.State.running      = false;
    App.State.paused       = false;
    App.State.remainingSecs = App.State.durationMins * 60;
    App.State.totalSecs    = App.State.remainingSecs;
    App.State.elapsedSecs  = 0;

    document.getElementById('stage')?.classList.remove('running');

    const stxt = document.getElementById('status-txt');
    if (stxt) stxt.textContent = 'READY';

    const sbtn = document.getElementById('btn-start');
    if (sbtn) sbtn.textContent = '▶\u00A0\u00A0Start Session';

    App.Console.log(`Timer reset → ${App.State.durationMins}m`, 'warn');
    render();
  }

  /** skip — immediately trigger session completion */
  function skip() {
    App.Console.log('Session skipped.', 'warn');
    clearInterval(App.State.intervalId);
    App.State.intervalId   = null;
    App.State.running      = false;
    App.State.remainingSecs = 0;
    render();
    onComplete();
  }

  /**
   * setMode — switch preset and reset
   * @param {string} key
   */
  function setMode(key) {
    if (!App.MODES[key]) return;
    App.State.mode        = key;
    App.State.durationMins = App.MODES[key].mins;
    reset();
    App.Console.log(`Mode → ${App.MODES[key].label} (${App.State.durationMins}m)`, 'info');
  }

  /**
   * setDuration — set custom minutes and reset
   * @param {number} mins
   */
  function setDuration(mins) {
    mins = Math.max(1, Math.min(999, mins));
    App.State.durationMins = mins;
    if (!App.State.running) reset();
    App.Console.log(`Duration → ${mins}m`, 'info');
  }

  return { start, pause, toggle, reset, skip, setMode, setDuration, render, fmt };
}());


/* ══════════════════════════════════════════════════════════════
   App.Missions — MISSION LOG MODULE
   ──────────────────────────────────────────────────────────────
   CRUD on an in-memory array, auto-synced to localStorage.
   Renders items with toggle-complete and delete affordances.
══════════════════════════════════════════════════════════════ */
App.Missions = (function () {

  /* @type {Array<{id:string, text:string, done:boolean, at:string}>} */
  let ms = [];

  /** uid — collision-resistant ID */
  const uid = () => `m${Date.now().toString(36)}${Math.random().toString(36).slice(2,6)}`;

  /**
   * render — rebuilds mission list DOM from `ms` array.
   * Re-attaches event handlers after each rebuild.
   */
  function render() {
    const list  = document.getElementById('mission-list');
    const empty = document.getElementById('mission-empty');
    const badge = document.getElementById('mission-badge');
    const stats = document.getElementById('m-stats');
    if (!list) return;

    const done  = ms.filter(m => m.done).length;
    const total = ms.length;

    if (badge) badge.textContent = `${done}/${total}`;
    if (stats) stats.textContent = `${done} completed`;
    if (empty) empty.style.display = total === 0 ? 'block' : 'none';

    /* Remove old items, leave empty-state node */
    list.querySelectorAll('.m-item').forEach(el => el.remove());

    ms.forEach(m => {
      const div = document.createElement('div');
      div.className = `m-item${m.done ? ' done' : ''}`;
      div.dataset.id = m.id;

      /* Escape HTML to prevent XSS from user text */
      const safe = m.text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');

      div.innerHTML = `
        <div class="m-check" role="checkbox" aria-checked="${m.done}" tabindex="0">
          <svg width="9" height="7" viewBox="0 0 9 7" fill="none">
            <path d="M1 3.5L3.5 6L8 1" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="m-text">${safe}</div>
        <button class="m-del" aria-label="Delete mission" title="Delete">×</button>
      `;

      div.querySelector('.m-check').addEventListener('click', () => toggle(m.id));
      div.querySelector('.m-del').addEventListener('click', e => { e.stopPropagation(); remove(m.id); });

      list.appendChild(div);
    });
  }

  function add(text) {
    const t = text.trim();
    if (!t) return;
    ms.push({ id:uid(), text:t, done:false, at:new Date().toISOString() });
    App.Storage.saveMissions(ms);
    render();
    App.Console.log(`Mission added: "${t}"`, 'info');
  }

  function toggle(id) {
    const m = ms.find(x => x.id === id);
    if (!m) return;
    m.done = !m.done;
    App.Storage.saveMissions(ms);
    render();
    App.Console.log(`Mission ${m.done ? 'completed' : 'reopened'}: "${m.text}"`, m.done ? 'success' : 'info');
  }

  function remove(id) {
    const m = ms.find(x => x.id === id);
    if (!m) return;
    ms = ms.filter(x => x.id !== id);
    App.Storage.saveMissions(ms);
    render();
    App.Console.log(`Mission removed: "${m.text}"`, 'warn');
  }

  function clearAll() {
    ms = [];
    App.Storage.saveMissions(ms);
    render();
    App.Console.log('Mission log cleared.', 'warn');
  }

  function load() {
    ms = App.Storage.loadMissions();
    render();
    App.Console.log(`Mission log loaded — ${ms.length} item(s).`, 'system');
  }

  return { add, toggle, remove, clearAll, load };
}());


/* ══════════════════════════════════════════════════════════════
   App.UI — DOM BINDING & RENDER HELPERS
   ──────────────────────────────────────────────────────────────
   Wires all interactive elements. Provides render helpers
   for stats and chip active states.
══════════════════════════════════════════════════════════════ */
App.UI = (function () {

  /** renderStats — refresh the stats bar from App.State */
  function renderStats() {
    const byId = (id, v) => { const e = document.getElementById(id); if (e) e.textContent = v; };
    byId('stat-sessions', App.State.sessions);
    byId('stat-focus',    `${App.State.focusMins}m`);
    byId('stat-streak',   App.State.streak);
  }

  function setActiveMode(key) {
    document.querySelectorAll('.mode-chip').forEach(c => c.classList.toggle('active', c.dataset.mode === key));
  }

  function setActiveDur(mins) {
    document.querySelectorAll('.dur-chip').forEach(c => c.classList.toggle('active', Number(c.dataset.mins) === mins));
  }

  /* ─── Bind: Unlock button ─── */
  function bindUnlock() {
    document.getElementById('btn-unlock')?.addEventListener('click', () => {
      App.Audio.init();

      const ov = document.getElementById('unlock-overlay');
      if (ov) { ov.classList.add('fade-out'); setTimeout(() => ov.remove(), 600); }

      App.Console.log('System initialized. Audio engine online.', 'success');
      App.Console.log('Shortcuts: [Space] start/pause · [R] reset · [S] skip', 'system');

      if ('Notification' in window && Notification.permission === 'default') {
        Notification.requestPermission();
      }
    });
  }

  /* ─── Bind: Timer buttons ─── */
  function bindTimer() {
    document.getElementById('btn-start')?.addEventListener('click', () => { App.Timer.toggle(); });
    document.getElementById('btn-reset')?.addEventListener('click', () => { App.Timer.reset(); });
    document.getElementById('btn-skip')?.addEventListener('click',  () => { App.Timer.skip(); });
  }

  /* ─── Bind: Mode chips ─── */
  function bindModes() {
    document.querySelectorAll('.mode-chip').forEach(c => {
      c.addEventListener('click', () => {
        App.Timer.setMode(c.dataset.mode);
        setActiveMode(c.dataset.mode);
        setActiveDur(App.MODES[c.dataset.mode].mins);
      });
    });
  }

  /* ─── Bind: Duration chips ─── */
  function bindDuration() {
    document.querySelectorAll('.dur-chip').forEach(c => {
      c.addEventListener('click', () => {
        const m = Number(c.dataset.mins);
        App.Timer.setDuration(m);
        setActiveDur(m);
      });
    });
  }

  /* ─── Bind: Environment mixer sliders ─── */
  function bindMixer() {
    const rainSlider   = document.getElementById('rain-slider');
    const forestSlider = document.getElementById('forest-slider');

    rainSlider?.addEventListener('input', () => {
      const pct = Number(rainSlider.value);
      App.Audio.setVolume('rain', pct / 100);
      const pctEl = document.getElementById('rain-pct');
      const sub   = document.getElementById('rain-sub');
      if (pctEl) pctEl.textContent = `${pct}%`;
      if (sub)   sub.textContent   = pct > 0 ? 'Active' : 'Idle';
      if (pct > 0) App.Console.log(`Rain volume → ${pct}%`, 'info');
    });

    forestSlider?.addEventListener('input', () => {
      const pct = Number(forestSlider.value);
      App.Audio.setVolume('forest', pct / 100);
      const pctEl = document.getElementById('forest-pct');
      const sub   = document.getElementById('forest-sub');
      if (pctEl) pctEl.textContent = `${pct}%`;
      if (sub)   sub.textContent   = pct > 0 ? 'Active' : 'Idle';
      if (pct > 0) App.Console.log(`Forest volume → ${pct}%`, 'info');
    });
  }

  /* ─── Bind: Mission log ─── */
  function bindMissions() {
    const inp    = document.getElementById('mission-inp');
    const addBtn = document.getElementById('btn-m-add');
    const clrBtn = document.getElementById('btn-m-clear');

    function doAdd() {
      if (!inp?.value.trim()) return;
      App.Missions.add(inp.value);
      inp.value = '';
      inp.focus();
    }

    addBtn?.addEventListener('click', doAdd);
    inp?.addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); doAdd(); } });
    clrBtn?.addEventListener('click', () => {
      if (confirm('Clear all missions from the log?')) App.Missions.clearAll();
    });
  }

  /* ─── Bind: Console actions ─── */
  function bindConsole() {
    document.getElementById('btn-con-clr')?.addEventListener('click', () => { App.Console.clear(); });
    document.getElementById('btn-con-exp')?.addEventListener('click', () => { App.Console.exportLog(); });
  }

  /* ─── Bind: Keyboard shortcuts ─── */
  function bindKeys() {
    document.addEventListener('keydown', e => {
      if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
      if (e.code === 'Space') { e.preventDefault(); App.Timer.toggle(); }
      if (e.code === 'KeyR')  App.Timer.reset();
      if (e.code === 'KeyS')  App.Timer.skip();
    });
  }

  return {
    renderStats, setActiveMode, setActiveDur,
    bindUnlock, bindTimer, bindModes, bindDuration,
    bindMixer, bindMissions, bindConsole, bindKeys,
  };
}());


/* ══════════════════════════════════════════════════════════════
   App.init — BOOTSTRAP
   ──────────────────────────────────────────────────────────────
   Runs on DOMContentLoaded. Sequence:
     1. Load + display persisted stats
     2. Load missions from storage
     3. Initialize timer display
     4. Set SVG ring dasharray
     5. Bind all event handlers
     6. Emit startup console log
══════════════════════════════════════════════════════════════ */
App.init = function () {
  /* 1. Stats */
  App.Storage.loadStats();
  App.UI.renderStats();

  /* 2. Missions */
  App.Missions.load();

  /* 3. Timer initial render */
  App.State.remainingSecs = App.State.durationMins * 60;
  App.State.totalSecs     = App.State.remainingSecs;
  App.Timer.render();

  /* 4. SVG ring: set dasharray so CSS transitions work */
  const rf = document.getElementById('ring-fill');
  if (rf) { rf.style.strokeDasharray = String(2 * Math.PI * 210); rf.style.strokeDashoffset = '0'; }

  /* 5. Event handlers */
  App.UI.bindUnlock();
  App.UI.bindTimer();
  App.UI.bindModes();
  App.UI.bindDuration();
  App.UI.bindMixer();
  App.UI.bindMissions();
  App.UI.bindConsole();
  App.UI.bindKeys();

  /* 6. Startup log */
  App.Console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'system');
  App.Console.log('  STASIS PRO v3.0.0 — Deep Focus Productivity System  ', 'system');
  App.Console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━', 'system');
  App.Console.log('Engine : Web Audio API — all sounds synthesized, zero external files', 'system');
  App.Console.log('Storage: localStorage — missions and stats auto-persist', 'system');
  App.Console.log(`Stats  : ${App.State.sessions} sessions · ${App.State.focusMins}m focus · streak ${App.State.streak}`, 'info');
  App.Console.log('Awaiting initialization — click "Initialize System" to unlock audio.', 'warn');
};

/* Boot */
if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', App.init);
else App.init();
</script>
