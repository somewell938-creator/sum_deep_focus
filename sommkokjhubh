<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>STASIS PRO — Deep Focus System</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Geist+Mono:wght@300;400;500&display=swap" rel="stylesheet" />

  <style>
    /* ═══════════════════════════════════════════════════════════
       STASIS PRO — DESIGN SYSTEM
       Palette: Midnight Espresso · Forest Emerald · Glass
       Typography: Space Grotesk (UI) + Geist Mono (terminal/timer)
    ═══════════════════════════════════════════════════════════ */
    :root {
      --bg-base:          #0A0A0B;
      --bg-surface:       #0e0e0f;
      --bg-elevated:      #131314;
      --glass:            rgba(255,255,255,0.03);
      --glass-hover:      rgba(255,255,255,0.055);
      --glass-active:     rgba(34,197,94,0.07);

      --border-subtle:    rgba(255,255,255,0.06);
      --border-default:   rgba(255,255,255,0.10);
      --border-strong:    rgba(255,255,255,0.16);
      --border-accent:    rgba(34,197,94,0.30);

      --text-primary:     rgba(255,255,255,0.92);
      --text-secondary:   rgba(255,255,255,0.50);
      --text-muted:       rgba(255,255,255,0.26);
      --text-accent:      #22C55E;
      --text-inverse:     #0A0A0B;

      --accent:           #22C55E;
      --accent-dim:       rgba(34,197,94,0.11);
      --accent-glow:      rgba(34,197,94,0.22);
      --accent-hover:     #1db352;

      --warn:             #F59E0B;
      --error:            #EF4444;
      --info:             #60A5FA;

      --radius-panel:     32px;
      --radius-card:      20px;
      --radius-item:      12px;
      --radius-btn:       10px;
      --radius-pill:      999px;

      --sidebar-w:        320px;
      --console-h:        206px;
      --header-h:         50px;

      --ease-smooth:      cubic-bezier(0.16,1,0.3,1);
      --ease-spring:      cubic-bezier(0.34,1.56,0.64,1);
    }

    *, *::before, *::after { box-sizing: border-box; margin:0; padding:0; }
    html, body { height:100%; overflow:hidden; }

    body {
      font-family: 'Space Grotesk', system-ui, sans-serif;
      background: var(--bg-base);
      color: var(--text-primary);
      font-size: 13.5px;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
    }

    button { font-family:inherit; cursor:pointer; border:none; outline:none; background:none; }
    input  { font-family:inherit; outline:none; border:none; background:none; color:inherit; }
    input::placeholder { color: var(--text-muted); }

    ::-webkit-scrollbar { width:3px; height:3px; }
    ::-webkit-scrollbar-track { background:transparent; }
    ::-webkit-scrollbar-thumb { background:var(--border-strong); border-radius:2px; }

    /* ─── UNLOCK OVERLAY ───────────────────────────────────────── */
    #unlock-overlay {
      position:fixed; inset:0; z-index:9999;
      background: var(--bg-base);
      display:flex; flex-direction:column; align-items:center; justify-content:center;
      transition: opacity 0.5s var(--ease-smooth);
    }
    #unlock-overlay.fade-out { opacity:0; pointer-events:none; }

    .unlock-mark {
      width:54px; height:54px; border-radius:16px;
      background:var(--accent-dim); border:1px solid var(--border-accent);
      display:flex; align-items:center; justify-content:center; margin-bottom:28px;
    }

    .unlock-eyebrow {
      font-size:11px; font-weight:600; letter-spacing:0.2em;
      text-transform:uppercase; color:var(--text-muted); margin-bottom:12px;
    }

    .unlock-title {
      font-size: clamp(40px,6vw,64px);
      font-weight:700; letter-spacing:-0.03em;
      color:var(--text-primary); margin-bottom:12px; text-align:center;
    }
    .unlock-title em { color:var(--accent); font-style:normal; }

    .unlock-sub {
      font-size:14px; color:var(--text-secondary); text-align:center;
      max-width:330px; line-height:1.7; margin-bottom:38px;
    }

    .unlock-btn {
      display:flex; align-items:center; gap:9px;
      padding:13px 28px; background:var(--accent); color:var(--text-inverse);
      font-size:14px; font-weight:600; border-radius:var(--radius-pill);
      transition: background 0.18s, transform 0.2s var(--ease-spring), box-shadow 0.2s;
    }
    .unlock-btn:hover {
      background:var(--accent-hover);
      transform:translateY(-2px); box-shadow:0 8px 32px var(--accent-glow);
    }
    .unlock-btn:active { transform:translateY(0); }

    .unlock-note {
      margin-top:18px; font-size:11.5px; color:var(--text-muted);
      display:flex; align-items:center; gap:6px;
    }

    /* ─── APP SHELL ─────────────────────────────────────────────── */
    #app {
      display:grid;
      grid-template-columns: var(--sidebar-w) 1fr;
      grid-template-rows: 1fr var(--console-h);
      height:100dvh; width:100vw;
    }

    /* ─── SIDEBAR ───────────────────────────────────────────────── */
    #sidebar {
      grid-column:1; grid-row:1/3;
      display:flex; flex-direction:column;
      border-right:1px solid var(--border-subtle);
      background:var(--bg-surface); overflow:hidden;
    }

    .sb-head {
      display:flex; align-items:center; gap:9px;
      padding:17px 18px 15px;
      border-bottom:1px solid var(--border-subtle);
      flex-shrink:0;
    }
    .sb-led {
      width:7px; height:7px; border-radius:50%; background:var(--accent);
      box-shadow:0 0 8px var(--accent-glow);
      animation: breathe 3s ease-in-out infinite;
    }
    @keyframes breathe {
      0%,100%{opacity:1;transform:scale(1);}
      50%{opacity:0.45;transform:scale(0.75);}
    }
    .sb-brand { font-size:11.5px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:var(--text-secondary); }
    .sb-ver   { margin-left:auto; font-size:10px; font-family:'Geist Mono',monospace; color:var(--text-muted); }

    .sb-body {
      display:flex; flex-direction:column; flex:1;
      overflow-y:auto; padding:14px 12px; gap:10px;
    }

    /* Panel card */
    .panel {
      background:var(--glass); border:1px solid var(--border-default);
      border-radius:var(--radius-panel); overflow:hidden;
    }
    .panel-head {
      display:flex; align-items:center; gap:8px;
      padding:13px 15px 11px; border-bottom:1px solid var(--border-subtle);
    }
    .panel-ico { font-size:14px; }
    .panel-lbl { font-size:10.5px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:var(--text-muted); }
    .panel-badge {
      margin-left:auto; font-size:10px; font-family:'Geist Mono',monospace;
      padding:2px 8px; border-radius:var(--radius-pill);
      background:var(--glass); border:1px solid var(--border-subtle); color:var(--text-muted);
    }

    /* Mode chips */
    .mode-chips { display:flex; flex-wrap:wrap; gap:6px; padding:12px 14px; }
    .mode-chip {
      display:flex; align-items:center; gap:5px;
      padding:6px 13px; border-radius:var(--radius-pill);
      border:1px solid var(--border-default); background:var(--glass);
      font-size:12px; font-weight:500; color:var(--text-secondary);
      transition: all 0.16s var(--ease-smooth);
    }
    .mode-chip:hover { border-color:var(--border-strong); color:var(--text-primary); background:var(--glass-hover); }
    .mode-chip.active { background:var(--glass-active); border-color:var(--border-accent); color:var(--accent); }
    .chip-dot { width:5px; height:5px; border-radius:50%; background:currentColor; opacity:0.6; }

    /* Env mixer */
    .env-body { padding:14px 15px; display:flex; flex-direction:column; gap:18px; }
    .env-track { display:flex; flex-direction:column; gap:9px; }
    .env-row { display:flex; align-items:center; justify-content:space-between; }
    .env-info { display:flex; align-items:center; gap:9px; }
    .env-ico {
      width:30px; height:30px; border-radius:9px;
      background:var(--glass); border:1px solid var(--border-subtle);
      display:flex; align-items:center; justify-content:center; font-size:14px; flex-shrink:0;
    }
    .env-name { font-size:13px; font-weight:500; }
    .env-sub  { font-size:10.5px; color:var(--text-muted); }
    .env-pct  { font-family:'Geist Mono',monospace; font-size:12px; color:var(--text-accent); min-width:34px; text-align:right; }

    input[type="range"] {
      -webkit-appearance:none; appearance:none;
      width:100%; height:3px; background:var(--border-default); border-radius:2px; cursor:pointer;
    }
    input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance:none; width:14px; height:14px; border-radius:50%;
      background:var(--accent); cursor:pointer;
      box-shadow:0 0 0 3px var(--accent-dim), 0 0 10px var(--accent-glow);
      transition:transform 0.14s var(--ease-spring);
    }
    input[type="range"]:hover::-webkit-slider-thumb { transform:scale(1.25); }
    input[type="range"]::-moz-range-thumb {
      width:14px; height:14px; border-radius:50%; background:var(--accent); border:none;
    }

    /* Mission log */
    .mission-body { padding:11px 13px; display:flex; flex-direction:column; gap:9px; }
    .mission-add {
      display:flex; gap:7px; align-items:center;
    }
    .mission-input-box {
      flex:1; display:flex; align-items:center; gap:7px;
      padding:8px 12px; border-radius:var(--radius-item);
      border:1px solid var(--border-default); background:var(--glass);
      transition:border-color 0.16s;
    }
    .mission-input-box:focus-within { border-color:var(--border-accent); background:var(--glass-active); }
    .mission-inp { flex:1; font-size:13px; }
    .mission-add-btn {
      width:34px; height:34px; border-radius:var(--radius-btn);
      background:var(--accent-dim); border:1px solid var(--border-accent);
      color:var(--accent); font-size:20px; line-height:1;
      display:flex; align-items:center; justify-content:center; flex-shrink:0;
      transition: background 0.16s, transform 0.15s var(--ease-spring);
    }
    .mission-add-btn:hover { background:rgba(34,197,94,0.2); transform:scale(1.07); }
    .mission-add-btn:active { transform:scale(0.95); }

    .mission-list { display:flex; flex-direction:column; gap:5px; max-height:220px; overflow-y:auto; padding-right:2px; }
    .mission-empty { text-align:center; padding:16px 0; font-size:12px; color:var(--text-muted); font-style:italic; }

    .m-item {
      display:flex; align-items:flex-start; gap:9px;
      padding:9px 10px; border-radius:var(--radius-item);
      border:1px solid var(--border-subtle); background:var(--glass);
      transition:all 0.16s; animation: m-in 0.22s var(--ease-spring);
    }
    @keyframes m-in { from{opacity:0;transform:translateY(-5px) scale(0.97);} to{opacity:1;transform:none;} }
    .m-item:hover { border-color:var(--border-default); background:var(--glass-hover); }
    .m-item.done { opacity:0.4; }
    .m-item.done .m-text { text-decoration:line-through; }

    .m-check {
      width:17px; height:17px; border-radius:5px;
      border:1.5px solid var(--border-strong); background:transparent;
      display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:1px;
      cursor:pointer; transition:all 0.16s;
    }
    .m-item.done .m-check { background:var(--accent); border-color:var(--accent); }
    .m-check svg { display:none; }
    .m-item.done .m-check svg { display:block; }

    .m-text { flex:1; font-size:12.5px; color:var(--text-secondary); line-height:1.4; word-break:break-word; }
    .m-del {
      width:20px; height:20px; border-radius:5px; color:var(--text-muted);
      display:flex; align-items:center; justify-content:center; font-size:15px; flex-shrink:0;
      opacity:0; transition:opacity 0.14s, color 0.14s, background 0.14s;
    }
    .m-item:hover .m-del { opacity:1; }
    .m-del:hover { color:var(--error); background:rgba(239,68,68,0.1); }

    .m-footer { display:flex; align-items:center; justify-content:space-between; }
    .m-stats-txt { font-size:11px; color:var(--text-muted); }
    .m-clear-btn {
      font-size:11px; color:var(--text-muted); padding:3px 8px;
      border-radius:5px; border:1px solid transparent; transition:all 0.14s;
    }
    .m-clear-btn:hover { color:var(--error); border-color:rgba(239,68,68,0.25); background:rgba(239,68,68,0.08); }

    /* ─── MAIN STAGE ─────────────────────────────────────────────── */
    #stage {
      grid-column:2; grid-row:1;
      display:flex; flex-direction:column; align-items:center; justify-content:center;
      position:relative; overflow:hidden; background:var(--bg-base);
    }

    /* Ambient radial glow — pulses when running */
    #stage::before {
      content:''; position:absolute; width:520px; height:520px;
      background:radial-gradient(circle, rgba(34,197,94,0.08) 0%, transparent 65%);
      border-radius:50%; top:50%; left:50%; transform:translate(-50%,-52%);
      pointer-events:none; opacity:0; transition:opacity 1.4s var(--ease-smooth);
    }
    #stage.running::before { opacity:1; }

    /* Subtle grid texture */
    #stage::after {
      content:''; position:absolute; inset:0;
      background-image:
        linear-gradient(var(--border-subtle) 1px, transparent 1px),
        linear-gradient(90deg, var(--border-subtle) 1px, transparent 1px);
      background-size:48px 48px;
      mask-image:radial-gradient(ellipse 65% 65% at 50% 50%, rgba(0,0,0,0.35) 0%, transparent 100%);
      pointer-events:none; opacity:0.45;
    }

    /* Stats bar */
    .stage-stats {
      position:absolute; top:0; left:0; right:0; z-index:3;
      display:flex; align-items:center;
      padding:0 22px; height:var(--header-h);
      border-bottom:1px solid var(--border-subtle);
    }
    .s-stat { display:flex; flex-direction:column; gap:1px; padding:0 16px; border-right:1px solid var(--border-subtle); }
    .s-stat:first-child { padding-left:0; }
    .s-stat:last-child  { border-right:none; }
    .s-val { font-family:'Geist Mono',monospace; font-size:14px; font-weight:500; font-variant-numeric:tabular-nums; }
    .s-lbl { font-size:10px; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; color:var(--text-muted); }
    .stage-stats-right { margin-left:auto; display:flex; gap:8px; align-items:center; }
    .mode-pill {
      padding:4px 11px; border-radius:var(--radius-pill);
      border:1px solid var(--border-default); font-size:11px; font-weight:600;
      letter-spacing:0.08em; text-transform:uppercase; color:var(--text-secondary);
      font-family:'Geist Mono',monospace;
    }

    /* Session status pill */
    .stage-status {
      position:relative; z-index:2;
      display:flex; align-items:center; gap:7px;
      padding:5px 14px; border-radius:var(--radius-pill);
      border:1px solid var(--border-subtle); background:var(--glass);
      font-size:10.5px; font-weight:600; letter-spacing:0.14em;
      text-transform:uppercase; color:var(--text-muted);
      margin-bottom:42px;
      transition:all 0.4s var(--ease-smooth);
    }
    #stage.running .stage-status { border-color:var(--border-accent); color:var(--accent); background:var(--accent-dim); }

    .s-led { width:6px; height:6px; border-radius:50%; background:currentColor; }
    #stage.running .s-led { animation:led 1.8s ease-in-out infinite; }
    @keyframes led {
      0%,100%{box-shadow:0 0 0 0 var(--accent-glow);}
      50%{box-shadow:0 0 0 6px transparent;}
    }

    /* Ring */
    .ring-wrap {
      position:absolute; top:50%; left:50%; transform:translate(-50%,-55%);
      pointer-events:none; z-index:1;
    }
    #p-ring { transform:rotate(-90deg); }
    .ring-track { fill:none; stroke:var(--border-subtle); stroke-width:1.5; }
    .ring-fill  { fill:none; stroke:var(--accent); stroke-width:1.5; stroke-linecap:round;
                  transition:stroke-dashoffset 1s linear;
                  filter:drop-shadow(0 0 7px var(--accent-glow)); }

    /* Timer */
    .timer-block { position:relative; z-index:2; display:flex; flex-direction:column; align-items:center; gap:9px; margin-bottom:48px; }

    #timer {
      font-family:'Space Grotesk', monospace;
      font-size: clamp(76px,11.5vw,156px);
      font-weight:700; letter-spacing:-0.04em; line-height:1;
      font-variant-numeric:tabular-nums;
      color:var(--text-primary); transition:color 0.5s;
      will-change:contents; transform:translateZ(0);
    }
    #timer.warn  { color:var(--warn); }
    #timer.crit  { color:var(--error); }

    .timer-sub {
      display:flex; align-items:center; gap:14px;
      font-size:11px; font-family:'Geist Mono',monospace;
      color:var(--text-muted); letter-spacing:0.07em;
    }
    .tsep { width:3px; height:3px; border-radius:50%; background:var(--border-strong); }

    /* Controls */
    .ctrl-row { position:relative; z-index:2; display:flex; align-items:center; gap:9px; }
    .ctrl-btn {
      display:flex; align-items:center; gap:7px;
      padding:10px 20px; border-radius:var(--radius-pill);
      border:1px solid var(--border-default); background:var(--glass);
      color:var(--text-secondary); font-size:13px; font-weight:500;
      transition:all 0.16s var(--ease-smooth);
    }
    .ctrl-btn:hover { border-color:var(--border-strong); background:var(--glass-hover); color:var(--text-primary); }
    .ctrl-btn:active { transform:scale(0.97); }

    .ctrl-primary {
      padding:12px 32px; background:var(--accent); border-color:transparent;
      color:var(--text-inverse); font-size:14px; font-weight:600;
      box-shadow:0 4px 24px var(--accent-glow);
      transition:all 0.18s var(--ease-spring);
    }
    .ctrl-primary:hover { background:var(--accent-hover); box-shadow:0 6px 32px var(--accent-glow); transform:translateY(-2px); }
    .ctrl-primary:active { transform:translateY(0) scale(0.98); }

    /* Duration chips */
    .dur-row { position:relative; z-index:2; display:flex; gap:5px; margin-top:26px; }
    .dur-chip {
      padding:5px 13px; border-radius:var(--radius-pill);
      border:1px solid var(--border-subtle); background:var(--glass);
      font-size:11.5px; font-family:'Geist Mono',monospace; color:var(--text-muted);
      transition:all 0.15s;
    }
    .dur-chip:hover { border-color:var(--border-default); color:var(--text-secondary); }
    .dur-chip.active { border-color:var(--border-accent); background:var(--accent-dim); color:var(--accent); }

    /* ─── CONSOLE DOCK ──────────────────────────────────────────── */
    #console {
      grid-column:2; grid-row:2;
      display:flex; flex-direction:column;
      border-top:1px solid var(--border-subtle);
      background:var(--bg-surface); overflow:hidden;
    }

    .con-head {
      display:flex; align-items:center; gap:9px;
      padding:0 15px; height:35px;
      border-bottom:1px solid var(--border-subtle); flex-shrink:0;
    }
    .con-dots { display:flex; gap:5px; }
    .con-dot  { width:8px; height:8px; border-radius:50%; }
    .con-dot:nth-child(1){background:#EF4444;}
    .con-dot:nth-child(2){background:#F59E0B;}
    .con-dot:nth-child(3){background:#22C55E;}
    .con-title { font-size:10.5px; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; color:var(--text-muted); font-family:'Geist Mono',monospace; }
    .con-actions { margin-left:auto; display:flex; gap:6px; }
    .con-btn {
      font-size:10.5px; font-family:'Geist Mono',monospace; color:var(--text-muted);
      padding:2px 9px; border-radius:5px; border:1px solid var(--border-subtle); background:transparent;
      transition:all 0.13s;
    }
    .con-btn:hover { color:var(--text-secondary); border-color:var(--border-default); background:var(--glass); }

    .con-output {
      flex:1; overflow-y:auto; padding:7px 15px 10px;
      display:flex; flex-direction:column; gap:1px;
    }

    .log-line {
      display:grid; grid-template-columns:78px 56px 1fr; gap:0;
      font-family:'Geist Mono',monospace; font-size:11.5px; line-height:1.72;
      animation: log-in 0.18s var(--ease-smooth);
    }
    @keyframes log-in { from{opacity:0;transform:translateY(3px);} to{opacity:1;transform:none;} }
    .l-ts    { color:var(--text-muted); }
    .l-lvl   { font-weight:600; }
    .l-msg   { color:var(--text-secondary); white-space:pre-wrap; word-break:break-all; }
    .l-lvl.info    { color:var(--info); }
    .l-lvl.success { color:var(--accent); }
    .l-lvl.warn    { color:var(--warn); }
    .l-lvl.error   { color:var(--error); }
    .l-lvl.system  { color:var(--text-muted); }

    /* Entrance animations */
    .a-in { animation: a-in 0.45s var(--ease-smooth) both; }
    @keyframes a-in { from{opacity:0;transform:translateY(10px);} to{opacity:1;transform:none;} }
    .d1{animation-delay:0.04s} .d2{animation-delay:0.1s} .d3{animation-delay:0.18s}
    .d4{animation-delay:0.27s} .d5{animation-delay:0.36s}
  </style>
</head>
<body>

<!-- ═══ UNLOCK OVERLAY ══════════════════════════════════════════ -->
<div id="unlock-overlay">
  <div class="unlock-mark">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
      <circle cx="12" cy="12" r="9" stroke="#22C55E" stroke-width="1.5"/>
      <path d="M12 7v5l3 3" stroke="#22C55E" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </div>
  <p class="unlock-eyebrow">Deep Focus System</p>
  <h1 class="unlock-title">STASIS <em>PRO</em></h1>
  <p class="unlock-sub">Initialize the audio engine to unlock ambient soundscapes synthesized entirely via Web Audio API — no files, pure code.</p>
